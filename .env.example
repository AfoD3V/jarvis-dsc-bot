NODE_ENV=development
LOG_LEVEL=info

DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_GUILD_ID=your-test-guild-id

BOT_QUEUE_NAME=jarvis-jobs
JOB_TIMEOUT_MS=180000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis_dev_password
POSTGRES_SSL=false

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

FACTCHECK_API_ENDPOINT=https://api.anthropic.com/v1/messages
FACTCHECK_API_KEY=your-factcheck-api-key
FACTCHECK_MODEL=claude-sonnet-4-20250514

SEARCH_API_ENDPOINT=https://api.tavily.com/search
SEARCH_API_KEY=your-search-api-key
SEARCH_MAX_RESULTS=5

BOT_HEALTH_PORT=3001
WORKER_HEALTH_PORT=3002
