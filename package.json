{
  "name": "jarvis-dsc-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start:bot": "node src/bot-api/index.js",
    "start:worker": "node src/worker/index.js",
    "dev:bot": "nodemon --watch src --watch scripts --ext js --signal SIGTERM src/bot-api/index.js",
    "dev:worker": "nodemon --watch src --watch scripts --ext js --signal SIGTERM src/worker/index.js",
    "db:migrate": "node scripts/migrate.js",
    "commands:sync": "node scripts/sync-commands.js",
    "check": "node scripts/check.js",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@google/genai": "^1.18.0",
    "@langchain/anthropic": "^0.3.26",
    "@langchain/core": "^0.3.68",
    "@langchain/google-genai": "^0.2.13",
    "@langchain/openai": "^0.3.16",
    "bullmq": "^5.12.12",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.4.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
